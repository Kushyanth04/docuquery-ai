# DocuQuery AI Environment Variables
# Copy this to .env and fill in your values

# ===== LLM Provider =====
# Options: "gemini" (free) or "openai" ($5 pay-as-you-go)
LLM_PROVIDER=gemini

# Google Gemini (free tier - 15 req/min)
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI (optional - pay-as-you-go)
OPENAI_API_KEY=your_openai_api_key_here

# ===== Embedding Provider =====
# Options: "huggingface" (free) or "openai" (pay-as-you-go)
EMBEDDING_PROVIDER=huggingface

# Hugging Face (free)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ===== Pinecone (free tier) =====
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=docuquery-index
PINECONE_ENVIRONMENT=us-east-1

# ===== Supabase (free tier) =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ===== Redis =====
# Local Docker: redis://localhost:6379
# Redis Cloud: redis://default:password@host:port
REDIS_URL=redis://localhost:6379

# ===== App Settings =====
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
